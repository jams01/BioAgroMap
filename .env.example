POSTGRES_DB=bioagromap
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
VITE_MAPBOX_TOKEN=

# --- Producción (Render + Vercel) ---
# Backend (Render): orígenes permitidos para el navegador (coma). Añade tu dominio custom si aplica.
# CORS_ORIGINS=https://tu-app.vercel.app,http://localhost:5173
# Opcional: regex Starlette para todas las previews Vercel (*.vercel.app).
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
# Frontend (Vercel build): URL pública del API sin barra final (el cliente añade /api/v1).
# VITE_API_URL=https://tu-servicio.onrender.com

# Copernicus Data Space (misma cuenta para descargas Sentinel-2 y Sentinel-1 en /preprocess)
COPERNICUS_USER=
COPERNICUS_PASSWORD=

# --- ESA SNAP (Earth Observation Toolbox) en Docker — NO es la tienda "Snap" de Ubuntu ---
# En Linux: /snap (squashfs) y ~/snap/ (Snapcraft) NO son lo mismo que /opt/snap (instalador ESA).
# Instalación recomendada: https://step.esa.int/main/download/snap-download/ → típicamente /opt/snap
# Ver en host: readlink -f "$(command -v gpt)"  → SNAP_HOST_MOUNT = carpeta raíz (contiene bin/gpt, jre, etc).
#
# SNAP_HOST_MOUNT=/opt/snap
# Arranque worker: docker compose -f docker-compose.yml -f docker-compose.snap.yml up -d worker
# SNAP_GPT_PATH=/opt/snap/bin/gpt
#
# Sin compose.snap: SNAP_GPT_PATH vacío; el backend prioriza /opt/snap y rutas ESA frente a un gpt genérico en PATH.
SNAP_GPT_PATH=
# Caché de tiles para ``gpt`` (subset S1); opcional, por defecto 4G en código.
# SNAP_GPT_CACHE=4G
# JVM extra en el worker (headless ya se fuerza; aquí p. ej. -Xmx8G)
# SNAP_JAVA_OPTS=-Xmx8G
# Lista explícita de bandas para el Subset S1 en GPT (opcional; si no, se prueban varias típicas IW GRD).
# SNAP_S1_SUBSET_SOURCE_BANDS=Amplitude_VV,Amplitude_VH
# Tras el subset, GPT aplica Terrain-Correction (DEM, espaciado y proyección opcionales).
# Por defecto: SRTM 1Sec HGT; nodata en mar desactivado (evita imagen toda a 0 en costa).
# SNAP_S1_TC_DEM=SRTM 1Sec HGT
# SNAP_S1_TC_PIXEL_SPACING_M=10.0
# SNAP_S1_TC_MAP_PROJECTION=AUTO:42001
# SNAP_S1_TC_NODATA_AT_SEA=1
# Con docker-compose.snap.yml el worker suele llevar S1_RECORTE_SNAP_ONLY=1 (solo SNAP, sin rasterio).
# Para permitir respaldo rasterio: S1_RECORTE_SNAP_ONLY=0

# API: tamaño máximo de subida en MB (rasters, ZIP de producto Sentinel-2, etc.)
MAX_UPLOAD_MB=4096
